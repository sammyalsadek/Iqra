{
  "name": "iqra",
  "version": "1.0.0",
  "description": "Quran vocabulary flashcards",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src",
    "check": "tsc --noEmit && eslint src --ext .ts && prettier --check src && knip",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "9.25.1",
    "eslint": "9.25.1",
    "husky": "9.1.7",
    "knip": "^6.4.1",
    "lint-staged": "15.5.1",
    "prettier": "3.5.3",
    "typescript": "5.8.3",
    "typescript-eslint": "8.31.0",
    "vite": "6.3.2"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.css": [
      "prettier --write"
    ]
  }
}
